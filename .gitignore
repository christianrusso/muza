# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# claude code local settings
.claude/settings.local.json

# claude code / agent skills instaladas localmente (tooling del entorno, no del producto)
.claude/skills/
.agents/
skills-lock.json

# vercel
.vercel

# eval harness output (reportes generados)
/scripts/eval/out/

# holdout del import (split reproducible por seed, no versionar)
/scripts/eval/holdout.txt

# fotos de prueba del eval (imágenes de personas, no van al repo)
# ahora vive en "LookLab Marketing/test-photos"; acá queda un symlink (tampoco se versiona)
/test-photos

# typescript
*.tsbuildinfo
next-env.d.ts

# Fotos de seed de comunidad (no versionar)
seed-fotos/**/*.jpg
seed-fotos/**/*.jpeg
seed-fotos/**/*.png
seed-fotos/**/*.webp
scripts/seed-fechas-backup-*.json
